<a
  href={`/api/checkout?productId=${POLAR_PRO_PRODUCT_ID}&customerEmail=${user.email}`}
  data-polar-checkout
  data-polar-checkout-theme="light"
>
  <Button size="lg">
    Upgrade to Pro вҖ” RM10/month
  </Button>
</a>
```

### 6.3 Webhook Handling

```typescript
// src/app/api/webhook/polar/route.ts
import { Webhooks } from "@polar-sh/nextjs";
import { db } from "@/db";
import { userEntitlements, webhookEvents } from "@/db/schema";
import { eq } from "drizzle-orm";

export const POST = Webhooks({
  webhookSecret: process.env.POLAR_WEBHOOK_SECRET!,

  onSubscriptionCreated: async (payload) => {
    await handleSubscriptionChange(payload, "active");
  },

  onSubscriptionUpdated: async (payload) => {
    await handleSubscriptionChange(
      payload,
      payload.data.status // "active" | "canceled" | "past_due" etc.
    );
  },

  onSubscriptionRevoked: async (payload) => {
    await handleSubscriptionChange(payload, "revoked");
  },
});

async function handleSubscriptionChange(
  payload: any,
  status: string
) {
  const eventId = payload.data.id + "_" + payload.type;

  // Idempotency check
  const existing = await db.query.webhookEvents.findFirst({
    where: eq(webhookEvents.eventId, eventId),
  });
  if (existing?.processedAt) return;

  // Store event
  await db.insert(webhookEvents).values({
    eventId,
    eventType: payload.type,
    payload: JSON.stringify(payload),
  }).onConflictDoNothing();

  // Resolve user by customer email
  const customerEmail = payload.data.customer?.email;
  if (!customerEmail) return;

  const user = await db.query.users.findFirst({
    where: eq(users.email, customerEmail),
  });
  if (!user) return;

  // Determine plan tier
  const planTier = ["active", "trialing"].includes(status) ? "pro" : "free";

  // Upsert entitlement
  await db
    .insert(userEntitlements)
    .values({
      userId: user.id,
      planTier,
      polarCustomerId: payload.data.customer?.id,
      polarSubscriptionId: payload.data.id,
      polarSubscriptionStatus: status,
      currentPeriodEnd: payload.data.currentPeriodEnd
        ? new Date(payload.data.currentPeriodEnd)
        : null,
    })
    .onConflictDoUpdate({
      target: userEntitlements.userId,
      set: {
        planTier,
        polarSubscriptionStatus: status,
        polarSubscriptionId: payload.data.id,
        currentPeriodEnd: payload.data.currentPeriodEnd
          ? new Date(payload.data.currentPeriodEnd)
          : null,
        updatedAt: new Date(),
      },
    });

  // Mark event processed
  await db
    .update(webhookEvents)
    .set({ processedAt: new Date() })
    .where(eq(webhookEvents.eventId, eventId));
}
```

### 6.4 Security

| Measure | Implementation |
|---------|---------------|
| **Signature verification** | `@polar-sh/nextjs` `Webhooks()` handles Standard Webhooks signature validation automatically |
| **Idempotency** | `webhook_events` table with unique `event_id` prevents duplicate processing |
| **Payload storage** | Full payload stored for audit trail |
| **Server-only** | Webhook secret never exposed to client; route is `POST`-only |

### 6.5 Local Data Stored

| Field | Source |
|-------|--------|
| `polar_customer_id` | From webhook `payload.data.customer.id` |
| `polar_subscription_id` | From webhook `payload.data.id` |
| `polar_subscription_status` | `active`, `canceled`, `past_due`, `revoked` |
| `current_period_end` | End of current billing period |
| `plan_tier` | Derived: `active`/`trialing` вҶ’ `pro`, else вҶ’ `free` |

