#### Calendar Page Skeleton

```typescript
// src/app/(app)/dashboard/page.tsx
import { auth } from "@/lib/auth";
import { headers } from "next/headers";
import { CalendarView } from "@/components/calendar/calendar-view";
import { UpcomingSidebar } from "@/components/sidebar/upcoming-sidebar";
import { getMonthOccurrences } from "@/actions/occurrences";
import { getUserItems } from "@/actions/items";

export default async function DashboardPage() {
  const session = await auth.api.getSession({
    headers: await headers(),
  });

  const now = new Date();
  const items = await getUserItems(session!.user.id);
  const occurrences = await getMonthOccurrences(
    session!.user.id,
    now.getFullYear(),
    now.getMonth()
  );

  return (
    <div className="flex flex-col lg:flex-row gap-6 p-6 max-w-7xl mx-auto">
      {/* Calendar Section */}
      <div className="flex-1 min-w-0">
        <CalendarView
          items={items}
          occurrences={occurrences}
          userId={session!.user.id}
        />
      </div>

      {/* Upcoming Sidebar */}
      <aside className="w-full lg:w-[380px] shrink-0">
        <UpcomingSidebar
          items={items}
          occurrences={occurrences}
        />
      </aside>
    </div>
  );
}
```

