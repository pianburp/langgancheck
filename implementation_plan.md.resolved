## 4. Database Schema (Neon + Drizzle)

### 4.1 Drizzle Schema

```typescript
// src/db/schema.ts
import {
  pgTable,
  text,
  timestamp,
  boolean,
  integer,
  decimal,
  pgEnum,
  index,
  uniqueIndex,
  uuid,
} from "drizzle-orm/pg-core";

// в”Җв”Җв”Җ Enums в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

export const itemTypeEnum = pgEnum("item_type", [
  "subscription",
  "bnpl",
]);

export const billingCycleEnum = pgEnum("billing_cycle", [
  "weekly",
  "biweekly",
  "monthly",
  "yearly",
]);

export const categoryEnum = pgEnum("category", [
  "entertainment",
  "food",
  "transport",
  "shopping",
  "gadget",
  "insurance",
  "education",
  "health",
  "utilities",
  "other",
]);

export const occurrenceStatusEnum = pgEnum("occurrence_status", [
  "upcoming",
  "paid",
  "missed",
  "skipped",
]);

export const planTierEnum = pgEnum("plan_tier", ["free", "pro"]);

// в”Җв”Җв”Җ Users (Better Auth managed + extended) в”Җв”Җв”Җв”Җв”Җв”Җв”Җ

export const users = pgTable("users", {
  id: text("id").primaryKey(),
  name: text("name").notNull(),
  email: text("email").notNull(),
  emailVerified: boolean("email_verified").notNull().default(false),
  image: text("image"),
  createdAt: timestamp("created_at").notNull().defaultNow(),
  updatedAt: timestamp("updated_at").notNull().defaultNow(),
});

export const sessions = pgTable("sessions", {
  id: text("id").primaryKey(),
  expiresAt: timestamp("expires_at").notNull(),
  token: text("token").notNull().unique(),
  createdAt: timestamp("created_at").notNull().defaultNow(),
  updatedAt: timestamp("updated_at").notNull().defaultNow(),
  ipAddress: text("ip_address"),
  userAgent: text("user_agent"),
  userId: text("user_id")
    .notNull()
    .references(() => users.id, { onDelete: "cascade" }),
});

export const accounts = pgTable("accounts", {
  id: text("id").primaryKey(),
  accountId: text("account_id").notNull(),
  providerId: text("provider_id").notNull(),
  userId: text("user_id")
    .notNull()
    .references(() => users.id, { onDelete: "cascade" }),
  accessToken: text("access_token"),
  refreshToken: text("refresh_token"),
  idToken: text("id_token"),
  accessTokenExpiresAt: timestamp("access_token_expires_at"),
  refreshTokenExpiresAt: timestamp("refresh_token_expires_at"),
  scope: text("scope"),
  password: text("password"),
  createdAt: timestamp("created_at").notNull().defaultNow(),
  updatedAt: timestamp("updated_at").notNull().defaultNow(),
});

export const verifications = pgTable("verifications", {
  id: text("id").primaryKey(),
  identifier: text("identifier").notNull(),
  value: text("value").notNull(),
  expiresAt: timestamp("expires_at").notNull(),
  createdAt: timestamp("created_at").defaultNow(),
  updatedAt: timestamp("updated_at").defaultNow(),
});

// в”Җв”Җв”Җ Entitlements / Plans в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

export const userEntitlements = pgTable(
  "user_entitlements",
  {
    id: uuid("id").defaultRandom().primaryKey(),
    userId: text("user_id")
      .notNull()
      .references(() => users.id, { onDelete: "cascade" }),
    planTier: planTierEnum("plan_tier").notNull().default("free"),

    // Polar subscription data
    polarCustomerId: text("polar_customer_id"),
    polarSubscriptionId: text("polar_subscription_id"),
    polarSubscriptionStatus: text("polar_subscription_status"),
    currentPeriodEnd: timestamp("current_period_end"),

    createdAt: timestamp("created_at").notNull().defaultNow(),
    updatedAt: timestamp("updated_at").notNull().defaultNow(),
  },
  (table) => [
    uniqueIndex("user_entitlements_user_id_idx").on(table.userId),
    index("user_entitlements_polar_customer_idx").on(table.polarCustomerId),
  ]
);

// в”Җв”Җв”Җ Tracked Items (Subscriptions + BNPL unified) в”Җ

export const items = pgTable(
  "items",
  {
    id: uuid("id").defaultRandom().primaryKey(),
    userId: text("user_id")
      .notNull()
      .references(() => users.id, { onDelete: "cascade" }),

    // Discriminator
    type: itemTypeEnum("type").notNull(),

    // Common fields
    name: text("name").notNull(),
    amount: decimal("amount", { precision: 10, scale: 2 }).notNull(),
    currency: text("currency").notNull().default("MYR"),
    billingCycle: billingCycleEnum("billing_cycle").notNull().default("monthly"),
    billingDay: integer("billing_day").notNull().default(1),
    startDate: timestamp("start_date", { mode: "date" }).notNull(),
    category: categoryEnum("category").notNull().default("other"),
    color: text("color").notNull().default("#6366F1"),
    notes: text("notes"),
    isActive: boolean("is_active").notNull().default(true),

    // BNPL-specific fields (null for subscriptions)
    totalInstallments: integer("total_installments"),
    installmentsPaid: integer("installments_paid").default(0),

    // Computed / cached
    nextDueDate: timestamp("next_due_date", { mode: "date" }),

    createdAt: timestamp("created_at").notNull().defaultNow(),
    updatedAt: timestamp("updated_at").notNull().defaultNow(),
  },
  (table) => [
    index("items_user_id_idx").on(table.userId),
    index("items_next_due_date_idx").on(table.nextDueDate),
    index("items_user_active_idx").on(table.userId, table.isActive),
  ]
);

// в”Җв”Җв”Җ Payment Occurrences в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

export const occurrences = pgTable(
  "occurrences",
  {
    id: uuid("id").defaultRandom().primaryKey(),
    itemId: uuid("item_id")
      .notNull()
      .references(() => items.id, { onDelete: "cascade" }),
    userId: text("user_id")
      .notNull()
      .references(() => users.id, { onDelete: "cascade" }),

    dueDate: timestamp("due_date", { mode: "date" }).notNull(),
    amount: decimal("amount", { precision: 10, scale: 2 }).notNull(),
    status: occurrenceStatusEnum("status").notNull().default("upcoming"),
    paidAt: timestamp("paid_at"),

    // For BNPL: which installment number is this?
    installmentNumber: integer("installment_number"),

    createdAt: timestamp("created_at").notNull().defaultNow(),
  },
  (table) => [
    index("occurrences_item_id_idx").on(table.itemId),
    index("occurrences_user_due_date_idx").on(table.userId, table.dueDate),
    index("occurrences_status_idx").on(table.status),
  ]
);

// в”Җв”Җв”Җ Webhook Events (idempotency + audit) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

export const webhookEvents = pgTable(
  "webhook_events",
  {
    id: uuid("id").defaultRandom().primaryKey(),
    eventId: text("event_id").notNull(),
    eventType: text("event_type").notNull(),
    payload: text("payload").notNull(), // JSON string
    processedAt: timestamp("processed_at"),
    createdAt: timestamp("created_at").notNull().defaultNow(),
  },
  (table) => [
    uniqueIndex("webhook_events_event_id_idx").on(table.eventId),
  ]
);
```

### 4.2 Free-Tier Enforcement (3 Active Items)

The limit is enforced **server-side** in the "create item" action:

```typescript
// src/actions/items.ts
async function assertCanCreateItem(userId: string) {
  const entitlement = await db.query.userEntitlements.findFirst({
    where: eq(userEntitlements.userId, userId),
  });

  // Pro users bypass limit
  if (entitlement?.planTier === "pro") return;

  // Count active items for free users
  const [{ count }] = await db
    .select({ count: sql<number>`count(*)` })
    .from(items)
    .where(and(eq(items.userId, userId), eq(items.isActive, true)));

  if (count >= 3) {
    throw new Error("UPGRADE_REQUIRED");
  }
}
```

The limit is **also enforced client-side** to show the upgrade dialog proactively before opening the add form.

### 4.3 Indexes & Constraints Summary

| Table | Key Indexes |
|-------|-------------|
| `items` | `(user_id)`, `(next_due_date)`, `(user_id, is_active)` |
| `occurrences` | `(item_id)`, `(user_id, due_date)`, `(status)` |
| `user_entitlements` | unique `(user_id)`, `(polar_customer_id)` |
| `webhook_events` | unique `(event_id)` вҖ” for idempotency |

---

## 5. Business Logic

### 5.1 Recurring Schedules

#### Subscriptions
- **Recurrence**: `billing_cycle` (weekly / monthly / yearly)
- **Anchor**: `billing_day` + `start_date`
- **`next_due_date`**: Cached on the `items` table, updated after each "mark as paid"
- **No end condition**: Runs until user pauses/cancels

**Calculation:**
```typescript
function getNextDueDate(
  currentDue: Date,
  cycle: "weekly" | "biweekly" | "monthly" | "yearly"
): Date {
  const next = new Date(currentDue);
  switch (cycle) {
    case "weekly":
      next.setDate(next.getDate() + 7);
      break;
    case "biweekly":
      next.setDate(next.getDate() + 14);
      break;
    case "monthly":
      next.setMonth(next.getMonth() + 1);
      break;
    case "yearly":
      next.setFullYear(next.getFullYear() + 1);
      break;
  }
  return next;
}
```

#### BNPL / Installments
- **Fixed count**: `total_installments` (e.g., 6)
- **Progress**: `installments_paid` incremented on each "mark as paid"
- **End condition**: `installments_paid >= total_installments` вҶ’ auto-set `is_active = false`
- **`next_due_date`**: Calculated same as subscription, but stops when complete

### 5.2 Calendar Event Rendering

For a given month view, we need items due in that month. Two strategies combined:

**Strategy: Hybrid (cached `next_due_date` + generated occurrences)**
1. When an item is created, generate `occurrences` rows for the next 3 months
2. A background job (or on-demand) extends occurrences when user navigates to future months
3. Calendar query:

```typescript
// Get all occurrences for a month
const monthOccurrences = await db
  .select()
  .from(occurrences)
  .innerJoin(items, eq(occurrences.itemId, items.id))
  .where(
    and(
      eq(occurrences.userId, userId),
      gte(occurrences.dueDate, monthStart),
      lte(occurrences.dueDate, monthEnd)
    )
  )
  .orderBy(asc(occurrences.dueDate));
```

**MVP simplification:** Generate occurrences on-the-fly for the visible month range at query time (no pre-generation needed). This avoids a background job for MVP.

```typescript
// src/lib/schedule.ts
function generateOccurrencesForRange(
  item: Item,
  rangeStart: Date,
  rangeEnd: Date
): GeneratedOccurrence[] {
  const occurrences: GeneratedOccurrence[] = [];
  let currentDate = new Date(item.startDate);
  let installmentNum = 0;

  while (currentDate <= rangeEnd) {
    if (currentDate >= rangeStart) {
      // For BNPL, stop after total installments
      if (item.type === "bnpl" && installmentNum >= item.totalInstallments!) {
        break;
      }
      occurrences.push({
        itemId: item.id,
        dueDate: new Date(currentDate),
        amount: item.amount,
        installmentNumber: item.type === "bnpl" ? installmentNum + 1 : null,
      });
    }
    installmentNum++;
    currentDate = getNextDueDate(currentDate, item.billingCycle);
  }
  return occurrences;
}
```

### 5.3 "Mark as Paid" Flow

```mermaid
flowchart TD
    A[User clicks Mark as Paid] --> B[Server action: markOccurrenceAsPaid]
    B --> C[Update occurrence: status=paid, paidAt=now]
    C --> D{Item type?}
    D -->|Subscription| E[Calculate next_due_date on item]
    D -->|BNPL| F[Increment installments_paid]
    F --> G{All paid?}
    G -->|Yes| H[Set item.is_active = false]
    G -->|No| E
    E --> I[Update item.next_due_date]
    I --> J[Return success + revalidate calendar]
```

**Server action:**
```typescript
async function markAsPaid(occurrenceId: string, userId: string) {
  return await db.transaction(async (tx) => {
    // 1. Update occurrence
    const [occ] = await tx
      .update(occurrences)
      .set({ status: "paid", paidAt: new Date() })
      .where(
        and(
          eq(occurrences.id, occurrenceId),
          eq(occurrences.userId, userId)
        )
      )
      .returning();

    // 2. Get parent item
    const [item] = await tx
      .select()
      .from(items)
      .where(eq(items.id, occ.itemId));

    // 3. Handle BNPL completion
    if (item.type === "bnpl") {
      const newPaid = (item.installmentsPaid ?? 0) + 1;
      const isComplete = newPaid >= (item.totalInstallments ?? 0);

      await tx.update(items).set({
        installmentsPaid: newPaid,
        isActive: !isComplete,
        nextDueDate: isComplete
          ? null
          : getNextDueDate(occ.dueDate, item.billingCycle),
        updatedAt: new Date(),
      }).where(eq(items.id, item.id));
    } else {
      // 4. Subscription: advance next_due_date
      await tx.update(items).set({
        nextDueDate: getNextDueDate(occ.dueDate, item.billingCycle),
        updatedAt: new Date(),
      }).where(eq(items.id, item.id));
    }
  });
}
```

### 5.4 Amount Changes & Pauses/Cancellations

| Action | Behavior |
|--------|----------|
| **Edit amount** | Only affects future occurrences. Previous paid records preserved. |
| **Pause (toggle inactive)** | Set `is_active = false`. Item stays in DB but excluded from calendar rendering and active count. |
| **Resume** | Set `is_active = true`. Recalculate `next_due_date` from today. |
| **Cancel/Delete** | Soft-delete: set `is_active = false` + keep data. Hard-delete optional via dropdown. |
| **Edit billing day** | Recalculate `next_due_date` from the new billing day. |

---

## 6. Payments (Polar)

### 6.1 Plan Product Mapping

| Plan | Polar Product | Price | Interval |
|------|---------------|-------|----------|
| Free | вҖ” (default) | RM 0 | вҖ” |
| Pro | `gajiguard-pro` product in Polar dashboard | RM 10.00 | Monthly |

Create in Polar Dashboard:
1. Product name: "GajiGuard Pro"
2. Price: RM 10.00 / month (MYR currency)
3. Get the **Product ID** (used in checkout URL)

### 6.2 Checkout Flow

```mermaid
sequenceDiagram
    participant U as User
    participant App as Next.js App
    participant Polar as Polar API
    
    U->>App: Clicks "Upgrade to Pro"
    App->>Polar: GET /checkout?productId=xxx&customerEmail=user@email.com
    Polar-->>U: Embedded checkout overlay
    U->>Polar: Completes payment
    Polar->>App: Webhook: subscription.created
    App->>App: Update user_entitlements вҶ’ plan_tier = "pro"
    App-->>U: Redirect to /dashboard?upgraded=true
```

**Checkout route handler:**
```typescript
// src/app/api/checkout/route.ts
import { Checkout } from "@polar-sh/nextjs";

export const GET = Checkout({
  accessToken: process.env.POLAR_ACCESS_TOKEN!,
  successUrl: `${process.env.NEXT_PUBLIC_APP_URL}/dashboard?checkout_id={CHECKOUT_ID}&upgraded=true`,
  server: process.env.NODE_ENV === "production" ? "production" : "sandbox",
});
```

**Checkout trigger (client):**
```typescript
